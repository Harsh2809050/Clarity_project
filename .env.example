# ── Beehiiv ──────────────────────────────────────────────────────────
# Get from: https://app.beehiiv.com/settings/api
BEEHIIV_API_KEY=your_api_key_here

# Get from: https://app.beehiiv.com/settings/general (Publication ID)
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── Analytics ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Admin Panel ───────────────────────────────────────────────────────
# Server-side only — NEVER use NEXT_PUBLIC_ for this
# Access your admin at /admin (no link shown to public users)
ADMIN_PASSWORD=change_this_to_something_strong

# ── Automation Webhook ────────────────────────────────────────────────
# Secret token to validate incoming webhook requests from Beehiiv/Make
WEBHOOK_SECRET=generate_a_random_string_here

# ── Zoho Mail SMTP (welcome emails) ───────────────────────────────────
# Use your existing Zoho Mail account at office@theclarityproject.in
# Host: smtp.zoho.in  (Indian accounts) OR smtp.zoho.com (others)
# Port: 465 with SSL=true  OR  587 with STARTTLS
# Password: use an App Password from Zoho Mail → Settings → Security → App Passwords
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=office@theclarityproject.in
ZOHO_SMTP_PASS=your_zoho_app_password_here

# ── Zoho CRM (optional) ───────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
